## TodoFlow (local development)
#
# Copy to `.env` (do not commit real secrets).
#
# --- docker compose (`docker compose up`)
#
# Postgres (`db` service)
POSTGRES_USER=todoflow
POSTGRES_PASSWORD=todoflow
POSTGRES_DB=todoflow
POSTGRES_PORT=5432
#
# Go API (`api` service, hot reload via air)
# Use host `db` when running inside Compose; use `localhost` when running the API on the host.
DATABASE_URL=postgres://todoflow:todoflow@db:5432/todoflow?sslmode=disable
PORT=8080
API_PORT=8080
CORS_ORIGIN=*
#
# Vite (`web` service) — server-side proxy only (see web/vite.config.ts)
API_PROXY_TARGET=http://api:8080
WEB_PORT=5173
#
# Secret / sensitive values (use strong passwords in real envs; never commit):
#   DATABASE_URL, POSTGRES_PASSWORD
#
# --- Run API or web on the host (outside Docker)
#
# Use DATABASE_URL with host `localhost` and omit API_PROXY_TARGET so Vite defaults to http://127.0.0.1:8080

# Frontend (Vite) — optional client-side base URL if the app uses it
VITE_API_BASE_URL=http://localhost:8080

# --- docker compose -f docker-compose.prod.yml
NGINX_PORT=80
# DATABASE_URL for api service should use host `db` when running in that stack.

# CI/CD (placeholders — set in GitHub Actions secrets or your deploy host)
# REGISTRY_TOKEN    — push images
# DEPLOY_SSH_KEY    — optional: SSH to VPS
# PRODUCTION_DATABASE_URL — managed Postgres in prod (rotate credentials)
