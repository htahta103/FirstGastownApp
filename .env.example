## TodoFlow (local development)
#
# Copy to `.env` (do not commit real secrets).
#
# Secret / sensitive values (use strong passwords in real envs; never commit):
#   DATABASE_URL      — Postgres connection string (user+password embedded)
#   POSTGRES_PASSWORD — only if you override Compose defaults for `db`
#
# Backend (Go API)
DATABASE_URL=postgres://todoflow:todoflow@localhost:5432/todoflow?sslmode=disable
PORT=8080
CORS_ORIGIN=*

# Frontend (Vite)
# Optional: app can use relative `/api` with Vite proxy.
VITE_API_BASE_URL=http://localhost:8080

# CI/CD (placeholders — set in GitHub Actions secrets or your deploy host)
# REGISTRY_TOKEN    — push images
# DEPLOY_SSH_KEY    — optional: SSH to VPS
# PRODUCTION_DATABASE_URL — managed Postgres in prod (rotate credentials)
