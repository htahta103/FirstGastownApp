# Local staging deploy config (for `make deploy-staging`).
#
# Copy to one of:
# - .env.staging
# - deploy/.env.staging
#
# Never commit real secrets. These values are typically non-secret (host + URL),
# but treat them as configuration for your environment.

# Required
DEPLOY_HOST_STAGING=staging.example.com
STAGING_URL=https://staging.example.com

# Optional
# DEPLOY_USER=deploy
# DEPLOY_PATH=/opt/todoflow
# HEALTH_PATH=/healthz
# ROOT_PATH=/

