# Local-only staging deploy configuration (do not commit).
#
# Usage:
#   cp deploy/env.staging.example .env.staging
#   # or: cp deploy/staging.env.example deploy/staging.env
#   $EDITOR .env.staging
#   make deploy-staging
#
# Required:
DEPLOY_HOST_STAGING=staging.example.com
STAGING_URL=https://staging.example.com
#
# Optional (defaults are in deploy/scripts/deploy-staging.sh):
# DEPLOY_USER=deploy
# DEPLOY_PATH=/opt/todoflow
# HEALTH_PATH=/healthz
# ROOT_PATH=/

