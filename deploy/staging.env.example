# Local-only staging deploy configuration (do not commit deploy/staging.env).
#
# Usage:
#   cp deploy/staging.env.example deploy/staging.env
#   $EDITOR deploy/staging.env
#   make deploy-staging
#
# Required:
DEPLOY_HOST_STAGING=staging.example.com
STAGING_URL=https://staging.example.com
#
# Optional (defaults are in deploy/scripts/deploy-staging.sh):
# DEPLOY_USER=deploy
# DEPLOY_PATH=/opt/todoflow
# HEALTH_PATH=/healthz
# ROOT_PATH=/

