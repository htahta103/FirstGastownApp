# Copy to deploy/.env on the server (never commit deploy/.env).
# docker compose --env-file deploy/.env -f deploy/docker-compose.prod.yaml ...

# --- PostgreSQL (docker service `db`) ---
POSTGRES_USER=todoflow
POSTGRES_PASSWORD=change-me-strong-secret
POSTGRES_DB=todoflow

# URL used by the API container (hostname `db` is the compose service name).
DATABASE_URL=postgres://todoflow:change-me-strong-secret@db:5432/todoflow?sslmode=disable

# --- API ---
PORT=8080
# Production: set to your public origin, e.g. https://tasks.example.com
CORS_ORIGIN=https://example.com

# Optional: pin a registry image instead of building on the server (uncomment and set).
# API_IMAGE=ghcr.io/your-org/todoflow-api:1.0.0

# --- Deploy script (run from your laptop) ---
# DEPLOY_HOST=vps.example.com
# DEPLOY_USER=deploy
# DEPLOY_PATH=/opt/todoflow

# --- Nginx / TLS (server paths; see deploy/README.md) ---
# TODOFLOW_DOMAIN=tasks.example.com

# --- Backups ---
# BACKUP_DIR=/var/backups/todoflow
# RETENTION_DAYS=14
